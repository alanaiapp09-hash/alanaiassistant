{
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npx vite",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "ALAN AI",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": true,
      "shell": { "open": true },
      "protocol": { "asset": true, "assetScope": ["**"] }
    },
    "bundle": {
      "active": true,
      "category": "DeveloperTool",
      "copyright": "Nexus LLC",
      "deb": { "depends": [] },
      "externalBin": [],
      "icon": ["icons/32x32.png","icons/128x128.png","icons/128x128@2x.png","icons/icon.icns","icons/icon.ico"],
      "identifier": "app.alanaiassistant",
      "longDescription": "ALAN AI - Tu asistente personal de inteligencia artificial",
      "macOS": {
        "entitlements": "entitlements.plist",
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      },
      "resources": ["../google-credentials.json"],
      "shortDescription": "ALAN AI Assistant",
      "targets": "all",
      "windows": { "certificateThumbprint": null, "digestAlgorithm": "sha256", "timestampUrl": "" }
    },
    "security": { "csp": "default-src 'self'; media-src 'self' blob: mediastream:; connect-src 'self' https: wss:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline';" },
    "updater": { "active": false },
    "windows": [{
      "fullscreen": false,
      "height": 750,
      "minHeight": 600,
      "minWidth": 800,
      "resizable": true,
      "title": "ALAN AI",
      "width": 1100
    }]
  }
}
